# BIT — Environment configuration example
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Bybit credentials ────────────────────────────────────────────────────────
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_TESTNET=true

# ── Trading mode ──────────────────────────────────────────────────────────────
# paper_trading=true means no real orders are placed.
# Switch to false ONLY after full paper trading validation.
PAPER_TRADING=true

# ── Capital ───────────────────────────────────────────────────────────────────
CAPITAL_USDT=500
MAX_POSITION_PCT=0.20
MAX_OPEN_POSITIONS=3

# ── Risk controls ─────────────────────────────────────────────────────────────
MAX_DRAWDOWN_PCT=0.10

# ── Paper trading simulation ──────────────────────────────────────────────────
PAPER_FEE_RATE=0.001
PAPER_SLIPPAGE_PCT=0.0005

# ── Signal thresholds ─────────────────────────────────────────────────────────
ENTER_THRESHOLD=0.65
MONITOR_THRESHOLD=0.40

# ── Exit thresholds ───────────────────────────────────────────────────────────
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.10
EXIT_SCORE_THRESHOLD=0.30

# ── Runner ────────────────────────────────────────────────────────────────────
# How often the bot checks each symbol (seconds). Default: 300 (5 minutes).
RUN_INTERVAL_SECONDS=300
